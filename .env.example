# ─────────────────────────────────────────────────────────────────────────────
# team-plus-server — environment
#
# Copy this file to `.env` and fill in the values below. `.env` is gitignored
# and holds your TeamPlus login + the instance URL. Other secrets live in their
# own gitignored files (see "Other config files" at the bottom).
#
#   cp .env.example .env
#   # then edit .env
# ─────────────────────────────────────────────────────────────────────────────

# Base URL (origin, no trailing slash) of your TeamPlus instance.
# Everything else — the WebSocket URL, the getToken endpoint, the REST API base,
# and the cookie domain — is derived from this, so no organisation URL is ever
# hardcoded in the source. Used by the local daemon (channel/), the cookie
# refresh scripts, and the dms skill.
#   e.g. https://team.your-org.example
TEAMPLUS_BASE=https://team.your-org.example

# TeamPlus login credentials, used ONLY by scripts/refresh_cookies.py to drive a
# headless browser login and capture fresh session cookies (cookies rotate ~7d).
# These never leave your machine.
TEAMPLUS_ACCOUNT=your-teamplus-username
TEAMPLUS_PASSWORD=your-teamplus-password

# ─────────────────────────────────────────────────────────────────────────────
# Other config files (each gitignored — create from its own template/setup):
#
#   .telegram.json   Telegram bridge bot. { "token": "...", "chat_id": "..." }
#                    Run: ./scripts/setup_telegram.sh
#
#   .config.json     Your TeamPlus numeric user id + mute lists.
#                    { "my_id": 0, "muted_chats": [], "muted_senders": [],
#                      "test_tag": "" }
#                    my_id is auto-filled by scripts/refresh_cookies.py.
#
#   cookies.json     Captured TeamPlus session cookies. Generated by
#                    ./scripts/refresh.sh — do not edit by hand.
#
# Cloud worker (optional — TeamPlus → Turso sync, see worker/README.md):
#
#   worker/.dev.vars   Turso creds + COOKIE_UPLOAD_SECRET + TEAMPLUS_BASE.
#                      See worker/.dev.vars.example; run worker/scripts/setup_turso.sh
#
#   .cf-worker.env     Deployed worker URL + matching upload secret, used by
#                      scripts/upload_cf_cookies.mjs. Auto-written by setup_turso.sh.
# ─────────────────────────────────────────────────────────────────────────────
