# TeamPlus cookie refresh — cloud cron (no laptop needed).
#
# Copy this file to `.github/workflows/refresh-cookies.yml` in your PRIVATE
# deployment repo (NOT the public one). It logs into TeamPlus on a GitHub-hosted
# runner, captures fresh session cookies, and uploads them to your Cloudflare
# worker so the Durable Object can reconnect.
#
# Add these as repository Secrets (Settings → Secrets and variables → Actions):
#   TEAMPLUS_ACCOUNT            your TeamPlus username
#   TEAMPLUS_PASSWORD          your TeamPlus password
#   TEAMPLUS_BASE              e.g. https://team.your-org.example
#   CF_TEAMPLUS_WORKER_URL     your deployed worker URL (https://<worker>.workers.dev)
#   CF_TEAMPLUS_UPLOAD_SECRET  the worker's COOKIE_UPLOAD_SECRET
#
# Secrets are encrypted by GitHub, never appear in the repo, and are masked in
# logs. Keep this workflow in a PRIVATE repo and only use schedule /
# workflow_dispatch triggers (never pull_request) so fork PRs can't reach them.

name: refresh-teamplus-cookies

on:
  schedule:
    # TSSID lives ~1 day, so refresh twice daily. Adjust to taste.
    - cron: '0 */12 * * *'
  workflow_dispatch: {}

concurrency:
  group: refresh-cookies
  cancel-in-progress: false

jobs:
  refresh:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install Tesseract OCR
        run: sudo apt-get update && sudo apt-get install -y tesseract-ocr

      - name: Write config from secrets
        env:
          TEAMPLUS_ACCOUNT: ${{ secrets.TEAMPLUS_ACCOUNT }}
          TEAMPLUS_PASSWORD: ${{ secrets.TEAMPLUS_PASSWORD }}
          TEAMPLUS_BASE: ${{ secrets.TEAMPLUS_BASE }}
          CF_TEAMPLUS_WORKER_URL: ${{ secrets.CF_TEAMPLUS_WORKER_URL }}
          CF_TEAMPLUS_UPLOAD_SECRET: ${{ secrets.CF_TEAMPLUS_UPLOAD_SECRET }}
        run: |
          umask 077
          printf 'TEAMPLUS_ACCOUNT=%s\nTEAMPLUS_PASSWORD=%s\nTEAMPLUS_BASE=%s\n' \
            "$TEAMPLUS_ACCOUNT" "$TEAMPLUS_PASSWORD" "$TEAMPLUS_BASE" > .env
          printf 'CF_TEAMPLUS_WORKER_URL=%s\nCF_TEAMPLUS_ACCOUNT_ID=default\nCF_TEAMPLUS_UPLOAD_SECRET=%s\n' \
            "$CF_TEAMPLUS_WORKER_URL" "$CF_TEAMPLUS_UPLOAD_SECRET" > .cf-worker.env

      - name: Refresh cookies and upload to worker
        run: ./scripts/refresh_and_upload_cf.sh --attempts 8
